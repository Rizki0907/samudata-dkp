// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SumberDataPT {
  PELABUHAN
  PUD
  KAB_KOTA
}

enum DataStatus {
  PENDING
  APPROVED
  REJECTED
}

// Tabel utama perikanan tangkap harian
model PerikananTangkap {
  id              Int           @id @default(autoincrement())
  sumber_data     SumberDataPT  @default(PELABUHAN)
  tanggal         DateTime
  jam_labuh       String?
  jam_bongkar     String?
  pelabuhan       String?
  kabupaten_kota  String?
  nama_kapal      String?
  gt_kapal        String?
  alat_tangkap    String?
  status          DataStatus @default(PENDING)
  alasan_penolakan String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tangkapan       DetailTangkapan[]
}

// Tabel Anak (Detail Ikan/Komoditas per Trip)
model DetailTangkapan {
  id                  Int               @id @default(autoincrement())
  perikanan_tangkap_id Int
  komoditas           String
  volume              Float    // kg
  harga               Float    // rupiah per kg
  nilai               Float    // otomatis: volume × harga
  
  perikananTangkap    PerikananTangkap  @relation(fields: [perikanan_tangkap_id], references: [id], onDelete: Cascade)
}

// Tabel untuk file upload sektor lain (metadata)
model FileUpload {
  id          Int      @id @default(autoincrement())
  sektor      String   // "budidaya", "garam", "ekspor", dst
  nama_file   String
  path_file   String
  ukuran      Int      // bytes
  tahun       Int?
  wilayah     String?
  uploaded_at DateTime @default(now())
}

// Tabel setting/konfigurasi (untuk kode admin, dll)
model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

// Tabel ekspor hasil perikanan
model Ekspor {
  id                  Int      @id @default(autoincrement())
  bulan               String
  tahun               String
  tanggal_ekspor      DateTime
  nama_eksportir      String
  kategori_komoditas  String
  nama_komoditas      String
  volume              Float    
  satuan_volume       String   
  nilai_usd           Float    
  negara_tujuan       String
  status              DataStatus @default(PENDING)
  alasan_penolakan    String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
}

// Tabel Budidaya Perikanan
model Budidaya {
  id              Int      @id @default(autoincrement())
  kabupaten_kota  String
  tahun           String
  bulan           String
  triwulan        String
  jenis_wadah     String
  produksi_ton    Float
  status          DataStatus @default(PENDING)
  alasan_penolakan String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}
